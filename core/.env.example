# Copie para core/.env ou defina no painel (Railway, etc.).
#
# --- Django ---
DJANGO_SECRET_KEY=troque-por-uma-chave-secreta-longa
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000
DJANGO_CSRF_TRUSTED_ORIGINS=https://seu-projeto.up.railway.app
DJANGO_LANGUAGE_CODE=pt-br
DJANGO_TIME_ZONE=America/Fortaleza
DJANGO_LOGIN_URL=/paineis/login/
DJANGO_LOGIN_REDIRECT_URL=/paineis/
DJANGO_LOGOUT_REDIRECT_URL=/paineis/login/

# --- Banco (obrigatório): uma única URL ---
# PostgreSQL (Railway injeta automaticamente):
# DATABASE_URL=postgres://user:pass@host:5432/dbname
#
# SQL Server + mssql-django — use o esquema mssqlms:// (mapeia para ENGINE "mssql"):
# DATABASE_URL=mssqlms://usuario:SENHA_URL_ENCODED@127.0.0.1:1433/NomeDoBanco?driver=ODBC+Driver+17+for+SQL+Server&Trusted_Connection=yes
#
# Opcional:
# DB_CONN_MAX_AGE=600
# DATABASE_SSL_REQUIRE=true
